# Copy to .env and fill in — every variable is required (see SETUP.md)

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/freelancer_marketplace

# JWT — generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Anthropic (AI job summarization + freelancer matching)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe test mode keys — https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen --forward-to localhost:8000/api/payments/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...
